# Server / Docker deployment template
# Copy to .env on the server, then fill in real secrets.

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=replace_with_strong_db_password
MYSQL_DATABASE=tl_compare
MYSQL_ROOT_PASSWORD=replace_with_strong_db_password
MYSQL_CHARSET=utf8mb4

# Uploads
UPLOAD_DIR=uploads

# Auth
JWT_SECRET_KEY=replace_with_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Admin bootstrap
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_admin_password

# LLM / VLM
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
VLM_API_KEY=
VLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VLM_MODEL=qwen-vl-max-latest
QWEN_API_KEY=
DASHSCOPE_API_KEY=

# AI detection
PRELOAD_AI_ASSETS=1
AI_DETECTION_PRELOAD=1
AI_MAX_CONCURRENT_TASKS=1
AI_GC_MAX_AGE_HOURS=24
AI_GC_INTERVAL_SECONDS=3600

# Fixed cache directories inside the container/image
AI_EASYOCR_MODEL_DIR=/opt/ai-assets/easyocr
AI_EASYOCR_DOWNLOAD_ENABLED=0
TORCH_HOME=/opt/ai-assets/torch

# Backend port
PORT=8000

# Optional
RELOAD=
LOG_LEVEL=INFO
LOG_FILE=
# CORS_ORIGINS=https://your-frontend.example.com
